@model Employee
@{
    ViewData["Title"] = "Delete";
}

<h1>Delete Employee</h1>
<br />

<h3 class="text-danger">Are you sure you want to delete this Employee?</h3>

<br />

<form asp-action="Delete">

    <input asp-for="Id" type="hidden" />

    <div class="form-group mb-3">
        <label asp-for="Name" class="col-form-label"></label>
        <input asp-for="Name" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Age" class="col-form-label"></label>
        <input asp-for="Age" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Address" class="col-form-label"></label>
        <input asp-for="Address" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Salary" class="col-form-label"></label>
        <input asp-for="Salary" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="IsActive" class="col-form-label"></label>
        <input asp-for="IsActive" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Email" class="col-form-label"></label>
        <input asp-for="Email" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="HiringDate" class="col-form-label"></label>
        <input asp-for="HiringDate" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="Gender" class="col-form-label"></label>
        <input asp-for="Gender" class="form-control" disabled />
    </div>

    <div class="form-group mb-3">
        <label asp-for="CreationDate" class="col-form-label"></label>
        <input asp-for="CreationDate" class="form-control" disabled />
    </div>

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>

</form>